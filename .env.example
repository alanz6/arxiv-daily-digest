# DigitalOcean Serverless Inference
# Get your key from https://cloud.digitalocean.com/account/api/tokens (under "Inference")
DO_INFERENCE_API_KEY=

# Default endpoint. Override if DigitalOcean gives you a different URL.
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1

# Model ID from DigitalOcean's model catalog (Llama 3.3, Mistral, etc.)
DO_INFERENCE_MODEL=llama3.3-70b-instruct

# Webapp login (single user)
APP_USERNAME=admin
# Generate with: python scripts/hash_password.py
APP_PASSWORD_HASH=

# Random string for session signing. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Optional Semantic Scholar API key (unauthenticated also works, just slower)
S2_API_KEY=

# Async concurrency limits. Higher = faster but more risk of DO rate-limiting.
# Hard cap is 60 in relevance.py; benchmark before pushing higher.
# SCORING_CONCURRENCY=40       # default 3; controls relevance scorer
# SCORING_BATCH_SIZE=5         # default 10; papers per LLM call
# SUMMARIZE_CONCURRENCY=10     # default 5; controls per-paper summarizer

# Embedding pre-filter. K scales with N (day's paper count) so recall stays
# stable as your daily volume changes:  K = max(MIN_K, round(RATIO * N)).
# Defaults give ~90% recall on the LLM's true top-10 (see docs/evaluation.md §4).
# Set EMBEDDING_FILTER_K to a non-empty integer to override with a fixed cap
# (0 disables the filter entirely).
# EMBEDDING_FILTER_K=
# EMBEDDING_FILTER_RATIO=0.62
# EMBEDDING_FILTER_MIN_K=50

# Optional overrides
# PROFILE_PATH=config/me.json
# DB_PATH=data/papers.db
